rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ------------------------------------------------------------------------
    // GLOBALS / HELPER FUNCTIONS
    // ------------------------------------------------------------------------

    // Global Safety Net: Default-deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ------------------------------------------------------------------------
    // USERS COLLECTION
    // ------------------------------------------------------------------------
    function isValidUser(data) {
        return data.keys().hasAll(['email', 'createdAt']) && data.keys().size() == 2
            && data.email is string && data.email.size() <= 128
            && data.createdAt is int;
    }

    match /users/{userId} {
        // Read: A verified user can read their own profile
        allow get: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
        
        // No blanket list on users
        allow list: if false;

        allow create: if isSignedIn() 
             && isValidId(userId) 
             && request.auth.uid == userId
             && isValidUser(incoming())
             && incoming().email == request.auth.token.email
             && incoming().createdAt == request.time.toMillis();
             
        allow update: if isSignedIn()
            && isValidId(userId)
            && request.auth.uid == userId
             // Because it's an update, we assume it's valid if nothing really changed, but size keys might be different 
             // We'll enforce no updates here as it's just profile initialization
            && incoming().diff(existing()).affectedKeys().size() == 0;
            
        // No delete
        allow delete: if false;
    }

    // ------------------------------------------------------------------------
    // CHARACTERS COLLECTION
    // ------------------------------------------------------------------------
    function isValidCharacter(data) {
        return data.keys().hasAll(['userId', 'name', 'class', 'race', 'createdAt', 'updatedAt']) 
            && data.userId is string && data.userId.size() <= 128
            && data.name is string && data.name.size() <= 32 && data.name.size() > 0
            && data.class is string && data.class.size() <= 32
            && data.race is string && data.race.size() <= 32
            && data.createdAt is int
            && data.updatedAt is int;
            // Equipment and inventory can be populated but are optional in this schema
    }

    match /characters/{characterId} {
        allow get: if isSignedIn() && isValidId(characterId) && (existing().userId == request.auth.uid || existing().activeZoneId != null);
        // User can only list their own characters or characters active in any zone
        allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.activeZoneId != null);

        allow create: if isSignedIn()
             && isValidId(characterId)
             && isValidCharacter(incoming())
             // Cannot create a character without existing user profile?
             && exists(/databases/$(database)/documents/users/$(request.auth.uid))
             && incoming().userId == request.auth.uid // Identity Integrity
             && incoming().createdAt == request.time.toMillis()
             && incoming().updatedAt == request.time.toMillis();

        allow update: if (
            isSignedIn() && isValidId(characterId) 
            && existing().userId == request.auth.uid
            && incoming().userId == existing().userId
        );

        allow delete: if isSignedIn() && isValidId(characterId) && existing().userId == request.auth.uid;
    }

    // ------------------------------------------------------------------------
    // AUCTIONS COLLECTION
    // ------------------------------------------------------------------------
    function isValidAuction(data) {
        return data.keys().hasAll(['sellerName', 'sellerId', 'item', 'price', 'createdAt'])
            && data.sellerName is string
            && data.sellerId is string
            && data.price is number
            && data.createdAt is int;
    }

    match /auctions/{auctionId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
             && isValidAuction(incoming())
             && (incoming().sellerId == request.auth.uid || incoming().sellerId == 'SIMULATED_SELLER');
        allow delete: if isSignedIn() && (existing().sellerId == request.auth.uid || existing().sellerId == 'SIMULATED_SELLER');
    }

    // ------------------------------------------------------------------------
    // CHAT MESSAGES COLLECTION
    // ------------------------------------------------------------------------
    function isValidChatMessage(data) {
        return data.keys().hasAll(['sender', 'userId', 'text', 'channel', 'createdAt'])
            && data.sender is string
            && data.userId is string
            && data.text is string && data.text.size() <= 500
            && data.channel is string
            && data.createdAt is int;
    }

    match /chat_messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
             && isValidChatMessage(incoming())
             && incoming().userId == request.auth.uid;
        allow delete: if false; // no deleting chat messages
    }

    // ------------------------------------------------------------------------
    // BANK ITEMS COLLECTION (GLOBAL SHARED)
    // ------------------------------------------------------------------------
    function isValidBankItem(data) {
        return data.keys().hasAll(['item', 'depositorName', 'createdAt'])
            && data.depositorName is string
            && data.createdAt is int;
    }

    match /bank_items/{itemId} {
        // Anyone can read and interact with the global bank
        allow read: if isSignedIn();
        allow create: if isSignedIn()
             && isValidBankItem(incoming());
        // Anyone can withdraw an item
        allow delete: if isSignedIn(); 
    }
  }
}
